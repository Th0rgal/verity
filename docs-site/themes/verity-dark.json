{
  "$schema": "https://raw.githubusercontent.com/shikijs/textmate-grammars-themes/main/packages/tm-themes/schema.json",
  "name": "Verity Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0F1B17",
    "editor.foreground": "#D2DDD8",
    "editorLineNumber.foreground": "#6B7B77",
    "editor.selectionBackground": "#1B3631",
    "editor.inactiveSelectionBackground": "#152825"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7E8C88",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted.double", "string.quoted.double.verity"],
      "settings": {
        "foreground": "#86A8A2"
      }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.hex", "constant.numeric.decimal", "constant.numeric.storage-slot", "constant.language.boolean", "constant.language.boolean.verity"],
      "settings": {
        "foreground": "#86C5B6"
      }
    },
    {
      "scope": ["keyword.declaration.contract.verity", "keyword.declaration.function.verity", "keyword.declaration.modifier.verity", "keyword.declaration.external.verity", "keyword.declaration.lean.verity"],
      "settings": {
        "foreground": "#5EEAD4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword", "keyword.other.section.verity", "keyword.other.section.linked-externals.verity", "source.lean keyword"],
      "settings": {
        "foreground": "#7CD4C0"
      }
    },
    {
      "scope": ["keyword.control.modifier-clause.verity", "storage.modifier.verity", "storage.modifier.reentrancy.verity", "keyword.control.do.verity", "keyword.control.lean.verity", "keyword.operator.assignment.verity", "keyword.operator", "punctuation.definition.parameters", "punctuation.separator", "punctuation.accessor.verity"],
      "settings": {
        "foreground": "#8E9E99"
      }
    },
    {
      "scope": ["entity.name.type.contract.verity", "storage.type.verity", "support.type", "entity.name.type", "storage.type"],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": ["entity.name.function.verity", "source.lean entity.name.function", "support.function.tactic.verity", "support.function.storage.verity", "support.function.context.verity", "support.function.arithmetic.verity", "support.function.spec.verity"],
      "settings": {
        "foreground": "#C7D5D1"
      }
    },
    {
      "scope": ["entity.name.function.external.verity", "support.function.external-call.verity"],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": ["entity.name.function.event.verity", "support.function.event.verity"],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": ["entity.name.function.modifier.verity", "variable.other.property.verity"],
      "settings": {
        "foreground": "#A8BCB6"
      }
    },
    {
      "scope": ["support.function.guard.verity", "entity.name.exception.custom-error.verity"],
      "settings": {
        "foreground": "#E5A18C"
      }
    },
    {
      "scope": ["support.function.loop.verity", "support.function.abi.verity"],
      "settings": {
        "foreground": "#9BB0AC"
      }
    },
    {
      "scope": ["variable.other.storage.verity", "variable.language.verity", "variable.other", "identifier"],
      "settings": {
        "foreground": "#C7D5D1"
      }
    },
    {
      "scope": ["meta.block.linked-externals.verity"],
      "settings": {
        "foreground": "#9BB0AC"
      }
    },

    {
      "scope": [
        "storage.type.contract",
        "storage.type.event",
        "storage.type.function",
        "storage.type.function.modifier",
        "storage.type.modifier",
        "storage.type.interface",
        "storage.type.library",
        "storage.type.struct",
        "storage.type.enum",
        "storage.type.error",
        "storage.type.mapping",
        "storage.type.constructor"
      ],
      "settings": {
        "foreground": "#5EEAD4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.pragma",
        "keyword.control.using",
        "keyword.control.for"
      ],
      "settings": {
        "foreground": "#7CD4C0"
      }
    },
    {
      "scope": [
        "storage.type.modifier.access",
        "storage.type.modifier.payable",
        "storage.type.modifier.readonly",
        "storage.type.modifier.extendedscope",
        "storage.modifier.is"
      ],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": [
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": [
        "entity.name.type.contract",
        "entity.name.type.contract.extend",
        "entity.name.type.interface",
        "entity.name.type.library",
        "entity.name.type.struct",
        "entity.name.type.enum",
        "entity.name.type.event",
        "entity.name.type.error",
        "entity.name.type.userType"
      ],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.modifier"
      ],
      "settings": {
        "foreground": "#C7D5D1"
      }
    },
    {
      "scope": [
        "support.function.math",
        "support.function.string",
        "keyword.control.exceptions",
        "keyword.control.contract"
      ],
      "settings": {
        "foreground": "#E5A18C"
      }
    },
    {
      "scope": [
        "variable.parameter.function",
        "variable.parameter.event",
        "variable.parameter.other"
      ],
      "settings": {
        "foreground": "#C7D5D1"
      }
    },
    {
      "scope": [
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.super",
        "variable.language.builtin.abi",
        "variable.language.transaction",
        "variable.language.type"
      ],
      "settings": {
        "foreground": "#9FBEB6"
      }
    },
    {
      "scope": [
        "constant.numeric.decimal",
        "constant.numeric.hexadecimal",
        "constant.numeric.scientific",
        "constant.language.boolean",
        "constant.language.currency",
        "constant.language.time"
      ],
      "settings": {
        "foreground": "#86C5B6"
      }
    },
    {
      "scope": [
        "string.quoted.double",
        "string.quoted.single"
      ],
      "settings": {
        "foreground": "#86A8A2"
      }
    },
    {
      "scope": [
        "keyword.operator.mapping",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.logic",
        "keyword.operator.binary"
      ],
      "settings": {
        "foreground": "#8E9E99"
      }
    }
  ],
  "semanticHighlighting": false
}
