{
  "$schema": "https://raw.githubusercontent.com/shikijs/textmate-grammars-themes/main/packages/tm-themes/schema.json",
  "name": "Verity Paper Light",
  "type": "light",
  "colors": {
    "editor.background": "#fbfcfb",
    "editor.foreground": "#1a2422",
    "editorLineNumber.foreground": "#a3aeab",
    "editor.selectionBackground": "#cfe6e0",
    "editor.inactiveSelectionBackground": "#dfece9"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6F807C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string.quoted.double", "string.quoted.double.verity"],
      "settings": {
        "foreground": "#2A6B61"
      }
    },
    {
      "scope": ["entity.name.function.event.verity"],
      "settings": {
        "foreground": "#0F8E7E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["constant.numeric", "constant.numeric.hex", "constant.numeric.decimal", "constant.numeric.storage-slot"],
      "settings": {
        "foreground": "#2A6B61"
      }
    },
    {
      "scope": ["constant.language.boolean", "constant.language.boolean.verity"],
      "settings": {
        "foreground": "#0B6E62",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.declaration.contract.verity", "keyword.declaration.function.verity", "keyword.declaration.modifier.verity", "keyword.declaration.external.verity", "keyword.other.section.verity", "keyword.other.section.linked-externals.verity"],
      "settings": {
        "foreground": "#0B6E62",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.control.modifier-clause.verity", "storage.modifier.verity", "storage.modifier.reentrancy.verity"],
      "settings": {
        "foreground": "#3D8579",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.control.do.verity", "keyword.control.lean.verity", "keyword.operator.assignment.verity"],
      "settings": {
        "foreground": "#6F807C"
      }
    },
    {
      "scope": ["keyword.operator", "punctuation.definition.parameters", "punctuation.separator", "punctuation.accessor.verity"],
      "settings": {
        "foreground": "#6F807C"
      }
    },
    {
      "scope": ["entity.name.type.contract.verity", "storage.type.verity", "support.type"],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.function.verity"],
      "settings": {
        "foreground": "#283531"
      }
    },
    {
      "scope": ["entity.name.function.external.verity"],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.function.modifier.verity"],
      "settings": {
        "foreground": "#3D8579",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.guard.verity"],
      "settings": {
        "foreground": "#B14A3A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.external-call.verity"],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.event.verity"],
      "settings": {
        "foreground": "#0F8E7E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.loop.verity"],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.abi.verity"],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.storage.verity", "support.function.context.verity", "support.function.arithmetic.verity", "support.function.spec.verity"],
      "settings": {
        "foreground": "#0F8E7E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["entity.name.exception.custom-error.verity"],
      "settings": {
        "foreground": "#B14A3A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable.other.property.verity"],
      "settings": {
        "foreground": "#3D8579",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable.other.storage.verity", "variable.language.verity", "variable.other"],
      "settings": {
        "foreground": "#2A3633"
      }
    },
    {
      "scope": ["meta.block.linked-externals.verity"],
      "settings": {
        "foreground": "#5E6E6A"
      }
    },
    {
      "scope": ["source.lean keyword", "keyword.declaration.lean.verity"],
      "settings": {
        "foreground": "#0B6E62",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["source.lean entity.name.function", "support.function.tactic.verity"],
      "settings": {
        "foreground": "#283531"
      }
    },

    {
      "scope": [
        "storage.type.contract",
        "storage.type.event",
        "storage.type.function",
        "storage.type.function.modifier",
        "storage.type.modifier",
        "storage.type.interface",
        "storage.type.library",
        "storage.type.struct",
        "storage.type.enum",
        "storage.type.error",
        "storage.type.mapping",
        "storage.type.constructor",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.pragma",
        "keyword.control.using",
        "keyword.control.for"
      ],
      "settings": {
        "foreground": "#0B6E62",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "storage.type.modifier.access",
        "storage.type.modifier.payable",
        "storage.type.modifier.readonly",
        "storage.type.modifier.extendedscope",
        "storage.modifier.is"
      ],
      "settings": {
        "foreground": "#3D8579",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.type.contract",
        "entity.name.type.contract.extend",
        "entity.name.type.interface",
        "entity.name.type.library",
        "entity.name.type.struct",
        "entity.name.type.enum",
        "entity.name.type.event",
        "entity.name.type.error",
        "entity.name.type.userType"
      ],
      "settings": {
        "foreground": "#1F5F58",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.function.modifier"
      ],
      "settings": {
        "foreground": "#283531"
      }
    },
    {
      "scope": [
        "support.function.math",
        "support.function.string",
        "keyword.control.exceptions",
        "keyword.control.contract"
      ],
      "settings": {
        "foreground": "#B14A3A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable.parameter.function",
        "variable.parameter.event",
        "variable.parameter.other"
      ],
      "settings": {
        "foreground": "#2A3633"
      }
    },
    {
      "scope": [
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#3D8579"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.super",
        "variable.language.builtin.abi",
        "variable.language.transaction",
        "variable.language.type"
      ],
      "settings": {
        "foreground": "#3D8579",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "constant.numeric.decimal",
        "constant.numeric.hexadecimal",
        "constant.numeric.scientific",
        "constant.language.boolean",
        "constant.language.currency",
        "constant.language.time"
      ],
      "settings": {
        "foreground": "#2A6B61"
      }
    },
    {
      "scope": [
        "string.quoted.double",
        "string.quoted.single"
      ],
      "settings": {
        "foreground": "#2A6B61"
      }
    },
    {
      "scope": [
        "keyword.operator.mapping",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.logic",
        "keyword.operator.binary"
      ],
      "settings": {
        "foreground": "#6F807C"
      }
    }
  ],
  "semanticHighlighting": false
}
