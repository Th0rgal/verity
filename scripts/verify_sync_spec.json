  ],
  "require_workflow_dispatch": true,
  "expected_jobs": [
    "changes",
    "checks",
    "timeout-watchdog",
    "build",
    "prepare-macro-fuzz",
    "build-audits",
    "macro-fuzz",
    "build-compiler-binaries",
    "generate-yul",
