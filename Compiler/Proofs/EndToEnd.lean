      NativeGeneratedSelectedUserBodyHaltExecBridgeAtFuel irContract tx state
        observableSlots) :
    NativeGeneratedSelectedUserBodyResultBridgeAtFuel irContract tx state
      observableSlots :=
  Or.inl hHalt

