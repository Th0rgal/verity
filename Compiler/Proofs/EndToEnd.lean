            some (tx.functionSelector, body') →
        Compiler.Proofs.YulGeneration.Backends.lowerStmtsNativeWithSwitchIds
            reservedNames bodyStart
            (Compiler.Proofs.YulGeneration.Backends.Native.switchCaseBody fn) =
