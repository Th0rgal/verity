              (EvmYul.UInt256.ofNat 0) (shared.sload (EvmYul.UInt256.ofNat 0)).2 })
      store codeOverride 0 32
  have hF : (fuel + 1) + 7 = fuel + 8 := by omega
  rw [hF] at hSeam
  simpa [simpleStorageLoweredRetrieveCaseBodyTail3] using hSeam

