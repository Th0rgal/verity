      simpleStorageNativeDispatcherInnerStmts =
        [EvmYul.Yul.Ast.Stmt.Let ["__has_selector"]
            (some (Backends.lowerExprNative
              (Yul.YulExpr.call "iszero"
                [Yul.YulExpr.call "lt"
