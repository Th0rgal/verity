     [.ExprStmtCall (Backends.lowerExprNative (.call "revert" [.lit 0, .lit 0]))],
   .ExprStmtCall (Backends.lowerExprNative
     (.call "mstore" [.lit 0, .call "sload" [.lit 0]])),
   .ExprStmtCall (Backends.lowerExprNative
     (.call "return" [.lit 0, .lit 32]))]

